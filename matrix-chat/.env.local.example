# Matrix homeserver URL 
VITE_MATRIX_BASE_URL=

# Matrix access token for the account that will post messages
VITE_MATRIX_ACCESS_TOKEN=

# The full Matrix user ID of that account
VITE_MATRIX_USER_ID=

# The Matrix room ID to connect to
VITE_MATRIX_ROOM_ID=

# Optional: the Matrix user ID of the Navigator account, used to style their messages differently
# Leave blank to skip navigator-vs-user distinction
VITE_MATRIX_NAVIGATOR_USER_ID=