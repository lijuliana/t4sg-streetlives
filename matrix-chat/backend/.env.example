# Copy this file to .env and fill in the values.
# backend/.env is gitignored — never commit real credentials.

# ── Matrix homeserver ──────────────────────────────────────────────────────────
MATRIX_BASE_URL=https://matrix.org

# ── Service account ────────────────────────────────────────────────────────────
# This account creates rooms and sends messages on behalf of guests.
# Use a dedicated bot account, not a personal Navigator account.
# The backend handles login and token refresh automatically — no manual
# token pasting required.
MATRIX_SERVICE_ACCOUNT_USER_ID=@streetlives-bot:matrix.org
MATRIX_SERVICE_ACCOUNT_PASSWORD=yourpassword

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
# Restrict CORS to the frontend origin.
CORS_ORIGIN=http://localhost:5173

# ── Optional: override where the Matrix session is persisted ───────────────────
# Defaults to .matrix-session.json in the backend working directory.
# MATRIX_SESSION_FILE=/path/to/.matrix-session.json
